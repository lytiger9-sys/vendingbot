<div class="mb-6">
  <h1 class="text-2xl font-bold">🛍️ 구매 내역</h1>
</div>
<div class="bg-gray-800 rounded-lg p-6">
  <table class="w-full">
    <thead>
      <tr class="text-left text-gray-400">
        <th class="pb-3">제품</th>
        <th class="pb-3">결제가격</th>
        <th class="pb-3">제공 내용</th>
        <th class="pb-3">후기</th>
        <th class="pb-3">일시</th>
      </tr>
    </thead>
    <tbody id="purchasesBody"></tbody>
  </table>
</div>
<div id="reviewModal" class="hidden fixed inset-0 bg-black/50 flex items-center justify-center z-50">
  <div class="bg-gray-800 rounded-lg p-6 w-96">
    <h3 class="text-lg font-bold mb-4">후기 작성</h3>
    <div class="mb-4"><label class="block text-sm text-gray-400 mb-2">평점</label><select id="rating"
        class="w-full p-2 rounded bg-gray-700 border border-gray-600">
        <option value="5">★★★★★</option>
        <option value="4">★★★★☆</option>
        <option value="3">★★★☆☆</option>
        <option value="2">★★☆☆☆</option>
        <option value="1">★☆☆☆☆</option>
      </select></div>
    <div class="mb-4"><label class="block text-sm text-gray-400 mb-2">후기</label><textarea id="reviewContent"
        class="w-full p-2 rounded bg-gray-700 border border-gray-600 h-24" placeholder="구매 후기를 남겨주세요..."></textarea>
    </div>
    <input type="hidden" id="receiptId">
    <div class="flex gap-2"><button onclick="submitReview()"
        class="flex-1 py-2 bg-blue-600 hover:bg-blue-700 rounded">작성완료</button><button onclick="closeModal()"
        class="flex-1 py-2 bg-gray-600 hover:bg-gray-500 rounded">취소</button></div>
  </div>
</div>
<script>
  async function load() {
    const r = await fetch("/dashboard/purchases");
    const d = await r.json();
    document.getElementById("purchasesBody").innerHTML = d.length === 0 ? "<tr><td colspan=5 class=\"text-gray-400 py-4\">구매 내역이 없습니다</td></tr>" : d.map(p => `<tr class=\"border-t border-gray-700\"><td class=\"py-3\">${p.product?.name || "알 수 없음"}</td><td class=\"py-3\">${p.paidAmount.toLocaleString()}원</td><td class=\"py-3 text-sm text-gray-300\">${p.deliveredContent || "-"}</td><td class=\"py-3\">${p.hasReview ? "<span class=\"text-green-400\">완료</span>" : `<button onclick=\"openModal("${p.id}")\" class=\"text-blue-400 hover:underline\">작성하기</button>`}</td><td class=\"py-3 text-gray-400 text-sm\">${new Date(p.purchasedAt).toLocaleString("ko-KR")}</td></tr>`).join("");
  }
  function openModal(id) { document.getElementById("receiptId").value = id; document.getElementById("reviewModal").classList.remove("hidden"); }
  function closeModal() { document.getElementById("reviewModal").classList.add("hidden"); }
  async function submitReview() { const r = await fetch("/dashboard/reviews", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ receiptId: document.getElementById("receiptId").value, rating: document.getElementById("rating").value, content: document.getElementById("reviewContent").value }) }); if (r.ok) { alert("후기가 등록되었습니다"); closeModal(); load(); } }
  load();
</script>