<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>내 대시보드</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="dashboard-container">
    <aside class="sidebar">
      <h1 class="sidebar-title">🛒 자판기 봇</h1>
      <nav class="sidebar-nav">
        <a href="/dashboard?tab=stats" class="nav-link" id="navStats"><span>📊</span> 내 통계</a>
        <a href="/dashboard?tab=purchases" class="nav-link" id="navPurchases"><span>🛍️</span> 구매 내역</a>
      </nav>
      <div class="sidebar-footer">
        <div class="user-profile">
          <% if (user.avatar) { %>
            <img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png?size=128" class="user-avatar" alt="프로필">
          <% } else { %>
            <img src="https://cdn.discordapp.com/embed/avatars/0.png" class="user-avatar" alt="프로필">
          <% } %>
          <div class="user-name"><%= user.username || '사용자' %></div>
        </div>
        <% if (isAdmin) { %>
          <a href="/admin" class="nav-link"><span>⚙️</span> 관리자 페이지</a>
        <% } %>
        <a href="/auth/logout" class="logout-link-animated"><span>🚪</span> 로그아웃</a>
      </div>
    </aside>
    <main class="main-content">
      <div class="page-header">
        <h1 class="title-md" id="pageTitle">📊 내 구매 통계</h1>
      </div>

      <!-- 내 통계 탭 -->
      <div id="statsTab" class="tab-content">
        <div class="stats-grid">
          <div class="stat-card success">
            <div class="stat-icon">💰</div>
            <div class="stat-value text-success" id="balance">로딩중...</div>
            <div class="stat-label">현재 잔액</div>
          </div>
          <div class="stat-card">
            <div class="stat-icon">🛒</div>
            <div class="stat-value text-primary" id="totalCount">로딩중...</div>
            <div class="stat-label">총 구매 횟수</div>
          </div>
          <div class="stat-card">
            <div class="stat-icon">💸</div>
            <div class="stat-value text-warning" id="totalSpent">로딩중...</div>
            <div class="stat-label">총 소비 금액</div>
          </div>
        </div>

        <div class="card mb-6">
          <div class="card-header">📈 월별 구매 추이</div>
          <canvas id="chart" height="100"></canvas>
        </div>
      </div>

      <!-- 구매 내역 탭 -->
      <div id="purchasesTab" class="tab-content hidden">
        <div class="card">
          <div class="card-header">🛍️ 최근 구매 내역</div>
          <div class="table-container">
            <table class="table">
              <thead>
                <tr>
                  <th>제품</th>
                  <th>가격</th>
                  <th>일시</th>
                  <th>후기</th>
                </tr>
              </thead>
              <tbody id="purchases"></tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- 후기 작성 모달 -->
      <div id="reviewModal" class="modal-overlay">
        <div class="modal">
          <div class="modal-header">
            ⭐ 후기 작성
            <button onclick="closeReviewModal()" class="modal-close">×</button>
          </div>
          <div class="input-group">
            <label class="input-label">평점</label>
            <select id="rating" class="input">
              <option value="5">★★★★★</option>
              <option value="4">★★★★☆</option>
              <option value="3">★★★☆☆</option>
              <option value="2">★★☆☆☆</option>
              <option value="1">★☆☆☆☆</option>
            </select>
          </div>
          <div class="input-group">
            <label class="input-label">후기 내용</label>
            <textarea id="reviewContent" class="input" rows="4" style="resize: vertical;"></textarea>
          </div>
          <input type="hidden" id="reviewReceiptId">
          <div class="modal-footer">
            <button onclick="closeReviewModal()" class="btn btn-outline">취소</button>
            <button onclick="submitReview()" class="btn btn-primary">작성완료</button>
          </div>
        </div>
      </div>

      <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
      <script>
        let chart, chart2;
        let purchases = [];

        // URL 파라미터로 초기 탭 결정
        const urlParams = new URLSearchParams(window.location.search);
        const currentTab = urlParams.get('tab') || 'stats';

        function showTab(tab) {
          history.pushState(null, '', '?tab=' + tab);
          
          const statsTab = document.getElementById('statsTab');
          const purchasesTab = document.getElementById('purchasesTab');
          const pageTitle = document.getElementById('pageTitle');
          const navStats = document.getElementById('navStats');
          const navPurchases = document.getElementById('navPurchases');
          
          if (tab === 'stats') {
            statsTab.classList.remove('hidden');
            purchasesTab.classList.add('hidden');
            pageTitle.textContent = '📊 내 구매 통계';
            navStats.classList.add('active');
            navPurchases.classList.remove('active');
          } else {
            statsTab.classList.add('hidden');
            purchasesTab.classList.remove('hidden');
            pageTitle.textContent = '🛍️ 구매 내역';
            navStats.classList.remove('active');
            navPurchases.classList.add('active');
            
            // 구매 내역 탭 로직
            if (!window.purchasesLoaded) {
              loadPurchases();
              window.purchasesLoaded = true;
            }
          }
        }

        async function loadStatsChart() {
          const r = await fetch("/dashboard/stats");
          const d = await r.json();
          document.getElementById("balance").textContent = (d.user.balance || 0).toLocaleString() + "원";
          document.getElementById("totalCount").textContent = d.totalPurchases;
          document.getElementById("totalSpent").textContent = (d.totalSpent || 0).toLocaleString() + "원";
          
          const year = new Date().getFullYear();
          const allMonths = Array.from({length: 12}, (_, i) => `${year}-${String(i + 1).padStart(2, '0')}`);
          const monthLabels = allMonths.map(m => {
            const [y, mo] = m.split('-');
            return `${y}년 ${parseInt(mo)}월`;
          });
          const amounts = allMonths.map(m => d.monthlyData[m]?.amount ?? null);
          
          if (chart) chart.destroy();
          chart = new Chart(document.getElementById("chart"), {
            type: "bar",
            data: {
              labels: monthLabels,
              datasets: [{
                label: "소비금액",
                data: amounts,
                backgroundColor: (ctx) => ctx.raw === null ? 'transparent' : '#8b5cf6',
                borderRadius: 6,
                barPercentage: 0.5,
                categoryPercentage: 0.8
              }]
            },
            options: {
              responsive: true,
              scales: {
                y: { beginAtZero: true, grid: { color: '#1a1a1a' } },
                x: { offset: true, grid: { display: false } }
              },
              plugins: { legend: { display: false } }
            }
          });
        }

        async function loadPurchasesChart() {
          const r = await fetch("/dashboard/stats");
          const d = await r.json();
          
          const year = new Date().getFullYear();
          const allMonths = Array.from({length: 12}, (_, i) => `${year}-${String(i + 1).padStart(2, '0')}`);
          const monthLabels = allMonths.map(m => {
            const [y, mo] = m.split('-');
            return `${y}년 ${parseInt(mo)}월`;
          });
          const amounts = allMonths.map(m => d.monthlyData[m]?.amount ?? null);
          
          if (chart2) chart2.destroy();
          chart2 = new Chart(document.getElementById("chart2"), {
            type: "bar",
            data: {
              labels: monthLabels,
              datasets: [{
                label: "소비금액",
                data: amounts,
                backgroundColor: (ctx) => ctx.raw === null ? 'transparent' : '#8b5cf6',
                borderRadius: 6,
                barPercentage: 0.5,
                categoryPercentage: 0.8
              }]
            },
            options: {
              responsive: true,
              scales: {
                y: { beginAtZero: true, grid: { color: '#1a1a1a' } },
                x: { offset: true, grid: { display: false } }
              },
              plugins: { legend: { display: false } }
            }
          });
        }

        async function loadPurchases() {
          const r = await fetch("/dashboard/purchases");
          purchases = await r.json();
          const tbody = document.getElementById("purchases");
          
          if (purchases.length === 0) {
            tbody.innerHTML = '<tr><td colspan="4" class="text-center py-4" style="color: #666;">구매 내역이 없습니다</td></tr>';
            return;
          }
          
          tbody.innerHTML = purchases.map(p => {
            const reviewButton = `<button onclick="openReviewModal('${p.id}')" class="btn btn-sm btn-primary">후기쓰기</button>`;
            
            return `
            <tr class="border-t border-gray-700">
              <td class="py-3">${p.product?.name || "알 수 없음"}</td>
              <td class="py-3">${p.paidAmount.toLocaleString()}원</td>
              <td class="py-3" style="color: #888;">${new Date(p.purchasedAt || p.createdAt).toLocaleString("ko-KR")}</td>
              <td class="py-3">
                ${p.hasReview ? 
                  '<span class="text-success">작성됨</span>' : 
                  reviewButton
                }
              </td>
            </tr>`;
          }).join("");
        }

        function openReviewModal(id) {
          document.getElementById("reviewReceiptId").value = id;
          document.getElementById("reviewModal").classList.remove("hidden");
        }

        function closeReviewModal() {
          document.getElementById("reviewModal").classList.add("hidden");
        }

        async function submitReview() {
          const r = await fetch("/dashboard/reviews", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              receiptId: document.getElementById("reviewReceiptId").value,
              rating: document.getElementById("rating").value,
              content: document.getElementById("reviewContent").value
            })
          });
          
          if (r.ok) {
            alert("후기가 작성되었습니다");
            closeReviewModal();
            loadPurchases();
          } else {
            alert("후기 작성에 실패했습니다.");
          }
        }

        // 초기화
        loadStatsChart();
        loadPurchases();
        showTab(currentTab);

        // 브라우저 뒤로가기/앞으로가기 지원
        window.addEventListener('popstate', () => {
          const params = new URLSearchParams(window.location.search);
          showTab(params.get('tab') || 'stats');
        });
      </script>
</main>
</div>
</body>
</html>