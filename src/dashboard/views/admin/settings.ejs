<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>설정</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="dashboard-container">
    <aside class="sidebar">
      <h1 class="sidebar-title">🛒 자판기 봇</h1>
      <nav class="sidebar-nav">
        <a href="/admin" class="nav-link"><span>📊</span> 월간 실적</a>
        <a href="/admin/products" class="nav-link"><span>📦</span> 제품</a>
        <a href="/admin/logs" class="nav-link"><span>📜</span> 로그</a>
        <a href="/admin/settings" class="nav-link active"><span>⚙️</span> 설정</a>
        <a href="/admin/roles" class="nav-link"><span>🎭</span> 역할 지급</a>
      </nav>
      <div class="sidebar-footer">
        <div class="user-id">ID: <%= user.id %></div>
        <a href="/" class="nav-link"><span>👤</span> 내 대시보드</a>
        <a href="/auth/logout" class="logout-link">🚪 로그아웃</a>
      </div>
    </aside>
    <main class="main-content">
<div class="page-header">
  <h1 class="title-md">⚙️ 자동충전/로그 설정</h1>
</div>

<div class="grid-2 mb-6">
  <div class="card">
    <div class="card-header">💰 계좌 정보</div>
    <div class="input-group">
      <input type="text" id="bankInfo" placeholder="은행명/계좌번호 (예: 국민 123-456-789)" class="input">
    </div>
    <div class="input-group">
      <input type="number" id="minDeposit" placeholder="최소 입금 금액" class="input">
    </div>
    <button onclick="saveBankSettings()" class="btn btn-primary" style="width: 100%;">저장</button>
  </div>
  <div class="card">
    <div class="card-header">📝 로그 채널 ID</div>
    <div class="input-group">
      <input type="text" id="manualLogChannel" placeholder="수동충전 로그 채널 ID" class="input">
    </div>
    <div class="input-group">
      <input type="text" id="purchaseLogChannel" placeholder="구매 로그 채널 ID" class="input">
    </div>
    <div class="input-group">
      <input type="text" id="failLogChannel" placeholder="충전 실패 로그 채널 ID" class="input">
    </div>
    <button onclick="saveChannelSettings()" class="btn btn-primary" style="width: 100%;">저장</button>
  </div>
</div>

<div class="card">
  <div class="card-header">📱 SMS 자동충전 가이드</div>
  <div class="flex gap-4 mb-4">
    <button onclick="showGuide('android')" id="btnAndroid" class="btn btn-success">안드로이드</button>
    <button onclick="showGuide('ios')" id="btnIos" class="btn btn-outline">아이폰</button>
  </div>
  <div id="guideContent" class="guide-box"></div>
</div>

<script>
  // 키값 매핑 테이블을 만들어 에러 발생 가능성을 원천 차단했습니다.
  const keyToIdMap = {
    "BANK_INFO": "bankInfo",
    "MIN_DEPOSIT": "minDeposit",
    "MANUAL_LOG_CHANNEL": "manualLogChannel",
    "PURCHASE_LOG_CHANNEL": "purchaseLogChannel",
    "FAIL_LOG_CHANNEL": "failLogChannel"
  };

  async function loadSettings() {
    try {
      const r = await fetch("/api/settings");
      const d = await r.json();
      
      d.settings.forEach(s => {
        const targetId = keyToIdMap[s.key];
        if (targetId) {
          const el = document.getElementById(targetId);
          if (el) el.value = s.value;
        }
      });
    } catch (e) {
      console.error("설정을 불러오는데 실패했습니다:", e);
    }
  }

  // 단일 설정 저장용 공통 함수
  async function saveSetting(k, v) {
    return await fetch("/api/settings", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ key: k, value: v })
    });
  }

  // 계좌 정보 그룹 일괄 저장
  async function saveBankSettings() {
    const bankInfo = document.getElementById("bankInfo").value;
    const minDeposit = document.getElementById("minDeposit").value;

    await saveSetting("BANK_INFO", bankInfo);
    await saveSetting("MIN_DEPOSIT", minDeposit);
    alert("계좌 정보가 저장되었습니다.");
  }

  // 로그 채널 설정 일괄 저장
  async function saveChannelSettings() {
    const ids = ["MANUAL_LOG_CHANNEL", "PURCHASE_LOG_CHANNEL", "FAIL_LOG_CHANNEL"];
    const vals = [
      document.getElementById("manualLogChannel").value,
      document.getElementById("purchaseLogChannel").value,
      document.getElementById("failLogChannel").value
    ];

    for (let i = 0; i < ids.length; i++) {
      if (vals[i] !== undefined) {
        await saveSetting(ids[i], vals[i]);
      }
    }
    alert("로그 채널 설정이 저장되었습니다.");
  }
  const androidGuide = `<안드로이드 SMS 웹훅 설정>

1. SMS Forwarder 앱 설치
2. Sender > Web 설정
3. URL에 SMS_WEBHOOK_URL 입력
4. Payload: {"content":"[SMS 수신 내용: {msg}] (발신자: {phone})"}
5. Rules > SMS 필터 설정
6. 입금 문구 포함 시 동작하도록 설정`;

  const iosGuide = `<아이폰 Shortcuts 설정>

1. 단축어 앱 > 자동화 탭
2. 메시지 트리거 추가
3. 송신자: 은행번호, 내용: 입금
4. 동작 추가 > URL
5. SMS_WEBHOOK_URL 입력
6. Get Contents of URL
7. Method: POST, Body: JSON
8. Key: content, Value: 메시지 텍스트`;

    function showGuide(type) {
    document.getElementById("guideContent").textContent = type === "android" ? androidGuide : iosGuide;
    document.getElementById("btnAndroid").className = type === "android" ? "btn btn-success" : "btn btn-outline";
    document.getElementById("btnIos").className = type === "ios" ? "btn btn-success" : "btn btn-outline";
  }

  loadSettings();
  showGuide("android");
</script>