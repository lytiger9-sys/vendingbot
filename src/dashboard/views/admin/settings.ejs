<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>설정</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="dashboard-container">
    <aside class="sidebar">
      <h1 class="sidebar-title">🛒 자판기 봇</h1>
      <nav class="sidebar-nav">
        <a href="/admin" class="nav-link"><span>📊</span> 월간 실적</a>
        <a href="/admin/products" class="nav-link"><span>📦</span> 제품</a>
        <a href="/admin/logs" class="nav-link"><span>📜</span> 로그</a>
        <a href="/admin/settings" class="nav-link active"><span>⚙️</span> 설정</a>
        <a href="/admin/embed" class="nav-link"><span>💬</span> 임베드</a>
        <a href="/admin/roles" class="nav-link"><span>🎭</span> 역할 지급</a>
      </nav>
      <div class="sidebar-footer">
        <div class="user-profile">
                  <% if (user.avatar) { %>
                    <img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png?size=128" class="user-avatar" alt="프로필">
                  <% } else { %>
                    <img src="https://cdn.discordapp.com/embed/avatars/0.png" class="user-avatar" alt="프로필">
                  <% } %>
                  <div class="user-name"><%= user.username || '관리자' %></div>
                </div>
                <a href="/dashboard" class="nav-link"><span>👤</span> 내 대시보드</a>
                <a href="/auth/logout" class="logout-link-animated"><span>🚪</span> 로그아웃</a>
      </div>
    </aside>
    
    <main class="main-content">
      <div class="page-header">
        <h1 class="title-md">⚙️ 자동충전/로그 설정</h1>
      </div>

            <div class="card mb-6">
              <div class="card-header">🔗 서버 링크</div>
              <div class="flex gap-2">
                <input type="text" id="serverLink" placeholder="https://discord.gg/xxxxx" class="input" style="flex: 1;">
                <button onclick="saveServerLink()" class="btn btn-primary">저장</button>
              </div>
            </div>

      <div class="settings-card-grid mb-6">
        <div class="card setting-equal-card">
          <div class="card-header">💰 계좌 정보</div>
          
          <div class="card-inner-flow left-inputs-balance">
            <div class="input-group">
              <input type="text" id="bankInfo" placeholder="은행명/계좌번호 (예: 국민 123-456-789)" class="input">
            </div>
            <div class="input-group">
              <input type="number" id="minDeposit" placeholder="최소 입금 금액" class="input">
            </div>
          </div>
          
          <div class="card-action-row">
            <button onclick="saveBankSettings()" class="btn btn-primary" style="width: 100%;">저장</button>
          </div>
        </div>
        
        <div class="card setting-equal-card">
          <div class="card-header">📝 로그 채널 ID</div>
          
          <div class="card-inner-flow right-inputs-balance">
            <div class="input-group">
              <input type="text" id="manualLogChannel" placeholder="수동충전 로그 채널 ID" class="input">
            </div>
            <div class="input-group">
              <input type="text" id="purchaseLogChannel" placeholder="구매 로그 채널 ID" class="input">
            </div>
            <div class="input-group">
              <input type="text" id="failLogChannel" placeholder="충전 실패 로그 채널 ID" class="input">
            </div>
          </div>
          
          <div class="card-action-row">
            <button onclick="saveChannelSettings()" class="btn btn-primary" style="width: 100%;">저장</button>
          </div>
        </div>
      </div>

      <div class="card">
        <div class="card-header">📱 SMS 자동충전 가이드</div>
        <div class="flex gap-4 mb-4">
          <button onclick="showGuide('android')" id="btnAndroid" class="btn btn-success">안드로이드</button>
          <button onclick="showGuide('ios')" id="btnIos" class="btn btn-outline">아이폰</button>
        </div>
        <div id="guideContent" class="guide-box"></div>
      </div>
    </main>
  </div>

  <style>
    /* 🛠️ 두 카드의 크기 및 정렬을 동일하게 제어하는 고정 프레임 구조 */
    @media (min-width: 769px) {
      .settings-card-grid {
        display: grid;
        grid-template-columns: 1fr 1fr; /* 좌우 가로폭 5:5 동일 배분 */
        gap: 24px;
      }
    }

    .setting-equal-card {
      display: flex;
      flex-direction: column;
      height: 100%; /* 카드 자체의 외부 총 높이를 고정 일치시킴 */
      min-height: 340px; /* 고정 크기를 잡기 위한 여유 스펙 설정 */
    }

    .setting-equal-card .card-header {
      margin-bottom: 12px;
    }

    /* 입력란들이 렌더링되는 가상의 세로 층(Flow) 박스 */
    .card-inner-flow {
      display: flex;
      flex-direction: column;
      flex: 1; /* 가용한 카드 여백 영역을 다 채우도록 지정 */
    }

    /* ✨ 핵심 교정: 왼쪽 카드는 2칸이므로 가상의 2, 4층에 자리잡도록 위아래 공백을 균등 분할 */
    .card-inner-flow.left-inputs-balance {
      justify-content: space-around; 
      padding: 10px 0; /* 외곽 미세 밸런스 조정 */
    }

    /* 오른쪽 카드는 3칸이므로 위아래 꽉 채워 1, 3, 5층 형태로 정렬하도록 제어 */
    .card-inner-flow.right-inputs-balance {
      justify-content: space-between;
    }

    /* 기본 마진 취소 처리 */
    .setting-equal-card .input-group {
      margin-bottom: 0 !important;
    }

    /* 두 카드의 [저장] 버튼 위치를 하단 바닥에 정위치 고정 */
    .card-action-row {
      margin-top: auto;
      padding-top: 16px;
    }

    .guide-box {
      background: var(--bg-darker, #252830);
      border: 1px solid var(--border-color, #333);
      border-radius: 8px;
      padding: 1.25rem;
      color: #dcddde;
      font-family: monospace;
      white-space: pre-wrap;
      line-height: 1.6;
    }
  </style>

  <script>
        const keyToIdMap = {
      "BANK_INFO": "bankInfo",
      "MIN_DEPOSIT": "minDeposit",
      "MANUAL_LOG_CHANNEL": "manualLogChannel",
      "PURCHASE_LOG_CHANNEL": "purchaseLogChannel",
      "FAIL_LOG_CHANNEL": "failLogChannel",
      "SERVER_LINK": "serverLink"
    };

    async function loadSettings() {
      try {
        const r = await fetch("/api/settings");
        const d = await r.json();
        
        d.settings.forEach(s => {
          const targetId = keyToIdMap[s.key];
          if (targetId) {
            const el = document.getElementById(targetId);
            if (el) el.value = s.value;
          }
        });
      } catch (e) {
        console.error("설정을 불러오는데 실패했습니다:", e);
      }
    }

    async function saveSetting(k, v) {
      return await fetch("/api/settings", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ key: k, value: v })
      });
    }

        async function saveServerLink() {
          const serverLink = document.getElementById("serverLink").value;
          await saveSetting("SERVER_LINK", serverLink);
          showToast("서버 링크가 저장되었습니다.", "success");
        }

        async function saveBankSettings() {
          const bankInfo = document.getElementById("bankInfo").value;
          const minDeposit = document.getElementById("minDeposit").value;

          await saveSetting("BANK_INFO", bankInfo);
          await saveSetting("MIN_DEPOSIT", minDeposit);
          showToast("계좌 정보가 저장되었습니다.", "success");
        }

    async function saveChannelSettings() {
      const ids = ["MANUAL_LOG_CHANNEL", "PURCHASE_LOG_CHANNEL", "FAIL_LOG_CHANNEL"];
      const vals = [
        document.getElementById("manualLogChannel").value,
        document.getElementById("purchaseLogChannel").value,
        document.getElementById("failLogChannel").value
      ];

      for (let i = 0; i < ids.length; i++) {
        if (vals[i] !== undefined) {
          await saveSetting(ids[i], vals[i]);
        }
      }
      showToast("로그 채널 설정이 저장되었습니다.", "success");
    }

    const androidGuide = `<안드로이드 SMS 웹훅 설정>

1. SMS Forwarder 앱 설치
2. Sender > Web 설정
3. URL에 SMS_WEBHOOK_URL 입력
4. Payload: {"content":"[SMS 수신 내용: {msg}] (발신자: {phone})"}
5. Rules > SMS 필터 설정
6. 입금 문구 포함 시 동작하도록 설정`;

    const iosGuide = `<아이폰 Shortcuts 설정>

1. 단축어 앱 > 자동화 탭
2. 메시지 트리거 추가
3. 송신자: 은행번호, 내용: 입금
4. 동작 추가 > URL
5. SMS_WEBHOOK_URL 입력
6. Get Contents of URL
7. Method: POST, Body: JSON
8. Key: content, Value: 메시지 텍스트`;

    function showGuide(type) {
      document.getElementById("guideContent").textContent = type === "android" ? androidGuide : iosGuide;
      document.getElementById("btnAndroid").className = type === "android" ? "btn btn-success" : "btn btn-outline";
      document.getElementById("btnIos").className = type === "ios" ? "btn btn-success" : "btn btn-outline";
    }

    loadSettings();
    showGuide("android");
  </script>
  <script src="/js/common.js"></script>
</body>
</html>