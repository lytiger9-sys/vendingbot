<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>시스템 설정</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="dashboard-container">
    <aside class="sidebar">
      <h1 class="sidebar-title">🛒 자판기 봇</h1>
      <nav class="sidebar-nav">
        <a href="/admin" class="nav-link"><span>📊</span> 월간 실적</a>
        <a href="/admin/products" class="nav-link"><span>📦</span> 제품</a>
        <a href="/admin/logs" class="nav-link"><span>📜</span> 로그</a>
        <a href="/admin/settings" class="nav-link active"><span>⚙️</span> 설정</a>
        <a href="/admin/embed" class="nav-link"><span>💬</span> 임베드</a>
        <a href="/admin/roles" class="nav-link"><span>🎭</span> 역할 지급</a>
      </nav>
      <div class="sidebar-footer">
        <div class="user-id">ID: <%= user.id %></div>
        <a href="/dashboard" class="nav-link"><span>👤</span> 내 대시보드</a>
        <a href="/auth/logout" class="logout-link-animated"><span>🚪</span> 로그아웃</a>
      </div>
    </aside>
    <main class="main-content">
      <div class="page-header">
        <h1 class="title-md">⚙️ 시스템 설정</h1>
      </div>

      <div class="card">
        <div class="card-header">📜 로그 채널 설정</div>
        
        <div class="input-group">
          <label class="input-label">구매 로그 채널 ID</label>
          <div class="flex gap-2">
            <input type="text" id="PURCHASE_LOG_CHANNEL" placeholder="채널 ID 입력" class="input" style="flex: 1;">
            <button onclick="saveSetting('PURCHASE_LOG_CHANNEL')" class="btn btn-primary">저장</button>
          </div>
          <p class="text-muted mt-1">제품 구매 시 로그가 전송될 채널입니다.</p>
        </div>

        <div class="input-group mt-6">
          <label class="input-label">충전 로그 채널 ID</label>
          <div class="flex gap-2">
            <input type="text" id="RECHARGE_LOG_CHANNEL" placeholder="채널 ID 입력" class="input" style="flex: 1;">
            <button onclick="saveSetting('RECHARGE_LOG_CHANNEL')" class="btn btn-primary">저장</button>
          </div>
          <p class="text-muted mt-1">사용자가 잔액을 충전했을 때 로그가 전송될 채널입니다.</p>
        </div>

        <div class="input-group mt-6">
          <label class="input-label">후기 로그 채널 ID</label>
          <div class="flex gap-2">
            <input type="text" id="REVIEW_LOG_CHANNEL" placeholder="채널 ID 입력" class="input" style="flex: 1;">
            <button onclick="saveSetting('REVIEW_LOG_CHANNEL')" class="btn btn-primary">저장</button>
          </div>
          <p class="text-muted mt-1">사용자가 후기를 작성했을 때 로그가 전송될 채널입니다.</p>
        </div>
      </div>

      <div class="card mt-6">
        <div class="card-header">🔗 기타 설정</div>
        <div class="input-group">
          <label class="input-label">서버 초대 링크</label>
          <div class="flex gap-2">
            <input type="text" id="SERVER_INVITE_LINK" placeholder="https://discord.gg/..." class="input" style="flex: 1;">
            <button onclick="saveSetting('SERVER_INVITE_LINK')" class="btn btn-primary">저장</button>
          </div>
        </div>
      </div>
    </main>
  </div>

  <script>
    async function loadSettings() {
      try {
        const r = await fetch('/api/settings');
        const d = await r.json();
        
        if (d.settings) {
          d.settings.forEach(s => {
            const el = document.getElementById(s.key);
            if (el) el.value = s.value;
          });
        }
      } catch (e) {
        console.error('설정 로드 실패:', e);
      }
    }

    async function saveSetting(key) {
      const value = document.getElementById(key).value.trim();
      if (!value) return alert('값을 입력해주세요.');

      try {
        const r = await fetch('/api/settings', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ key, value })
        });
        if (r.ok) {
          toast('설정이 저장되었습니다.', 'success');
        } else {
          throw new Error('저장 실패');
        }
      } catch (e) {
        toast('저장에 실패했습니다.', 'error');
      }
    }

    loadSettings();
  </script>
  <script src="/js/common.js"></script>
</body>
</html>
