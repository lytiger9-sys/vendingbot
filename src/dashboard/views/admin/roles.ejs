<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>역할 지급 설정</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="dashboard-container">
    <aside class="sidebar">
      <h1 class="sidebar-title">🛒 자판기 봇</h1>
      <nav class="sidebar-nav">
        <a href="/admin" class="nav-link"><span>📊</span> 월간 실적</a>
        <a href="/admin/products" class="nav-link"><span>📦</span> 제품</a>
        <a href="/admin/logs" class="nav-link"><span>📜</span> 로그</a>
        <a href="/admin/settings" class="nav-link"><span>⚙️</span> 설정</a>
        <a href="/admin/embed" class="nav-link"><span>💬</span> 임베드</a>
        <a href="/admin/roles" class="nav-link active"><span>🎭</span> 역할 지급</a>
      </nav>
      <div class="sidebar-footer">
        <div class="user-profile">
                  <% if (user.avatar) { %>
                    <img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png?size=128" class="user-avatar" alt="프로필">
                  <% } else { %>
                    <img src="https://cdn.discordapp.com/embed/avatars/0.png" class="user-avatar" alt="프로필">
                  <% } %>
                  <div class="user-name"><%= user.username || '관리자' %></div>
                </div>
                <a href="/dashboard" class="nav-link"><span>👤</span> 내 대시보드</a>
                <a href="/auth/logout" class="logout-link-animated"><span>🚪</span> 로그아웃</a>
      </div>
    </aside>
    <main class="main-content">
      <div class="page-header">
        <h1 class="title-md">🎭 역할 지급 설정</h1>
      </div>

            <div class="card mb-6">
        <div class="card-header">➕ 새 역할 보상 추가</div>
        <div style="display: grid; grid-template-columns: 1fr 1fr 1fr auto; align-items: end; gap: 1rem;">
          <div class="input-group">
            <label class="input-label">누적 소비 금액 (원)</label>
            <input type="number" id="spentLimit" placeholder="예: 10000" class="input">
          </div>
          <div class="input-group">
            <label class="input-label">역할 ID</label>
            <input type="text" id="roleId" placeholder="Discord 역할 ID" class="input">
          </div>
          <div class="input-group">
            <label class="input-label">할인률 (%)</label>
            <input type="number" id="discountRate" placeholder="예: 10" class="input" min="0" max="100">
          </div>
          <button onclick="addRole()" class="btn btn-primary" style="margin-bottom: 0.5rem;">추가하기</button>
        </div>
      </div>

      <div class="card">
        <div class="card-header">📜 역할 보상 목록</div>
        <div class="table-container">
                    <table class="table">
                      <thead>
                        <tr>
                          <th>누적 소비 금액</th>
                          <th>역할 ID</th>
                          <th>역할 이름</th>
                          <th>할인률</th>
                          <th>작업</th>
                        </tr>
                      </thead>
                      <tbody id="roleList">
                        <tr>
                          <td colspan="5" class="text-muted">로딩중...</td>
                        </tr>
                      </tbody>
                    </table>
        </div>
      </div>
    </main>
  </div>

    <script>
    async function loadRoles() {
      const r = await fetch('/api/admin/roles');
      const d = await r.json();
      const tb = document.getElementById('roleList');
            if (d.length === 0) {
              tb.innerHTML = '<tr><td colspan="5" class="text-muted">설정된 역할 보상이 없습니다.</td></tr>';
              return;
            }
            tb.innerHTML = d.map(r => `
              <tr class="border-t border-gray-700">
                <td class="py-3">${r.spentLimit.toLocaleString()}원</td>
                <td class="py-3">${r.roleId}</td>
                <td class="py-3">${r.roleName || '-'}</td>
                <td class="py-3">${r.discountRate > 0 ? `<span class="badge badge-success">${r.discountRate}%</span>` : '-'}</td>
                <td class="py-3">
                  <button onclick="deleteRole(${r.id})" class="text-danger hover:underline">삭제</button>
                </td>
              </tr>
            `).join("");
    }

    async function addRole() {
      const spentLimit = document.getElementById('spentLimit').value;
      const roleId = document.getElementById('roleId').value;
      const discountRate = document.getElementById('discountRate').value || 0;
      if (!spentLimit || !roleId) return showToast('누적 소비 금액과 역할 ID를 입력해주세요.', 'warning');

      const r = await fetch('/api/admin/roles', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ spentLimit: parseInt(spentLimit), roleId, discountRate: parseInt(discountRate) })
      });

      if (r.ok) {
        document.getElementById('spentLimit').value = '';
        document.getElementById('roleId').value = '';
        document.getElementById('discountRate').value = '';
        showToast('역할 보상이 추가되었습니다.', 'success');
        loadRoles();
      } else {
        showToast('추가 실패', 'error');
      }
    }

    async function deleteRole(id) {
      showConfirm('정말 삭제하시겠습니까?', async () => {
        const r = await fetch(`/api/admin/roles/${id}`, { method: 'DELETE' });
        if (r.ok) {
          showToast('삭제되었습니다.', 'success');
          loadRoles();
        } else {
          showToast('삭제 실패', 'error');
        }
      });
    }

    loadRoles();
  </script>
  <script src="/js/common.js"></script>
</body>
</html>
