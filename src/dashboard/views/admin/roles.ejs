<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>역할 지급 설정</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="dashboard-container">
    <aside class="sidebar">
      <h1 class="sidebar-title">🛒 자판기 봇</h1>
      <nav class="sidebar-nav">
        <a href="/admin" class="nav-link"><span>📊</span> 월간 실적</a>
        <a href="/admin/products" class="nav-link"><span>📦</span> 제품</a>
        <a href="/admin/logs" class="nav-link"><span>📜</span> 로그</a>
        <a href="/admin/settings" class="nav-link"><span>⚙️</span> 설정</a>
        <a href="/admin/embed" class="nav-link"><span>💬</span> 임베드</a>
        <a href="/admin/roles" class="nav-link active"><span>🎭</span> 역할 지급</a>
      </nav>
      <div class="sidebar-footer">
        <div class="user-id">ID: <%= user.id %></div>
        <a href="/dashboard" class="nav-link"><span>👤</span> 내 대시보드</a>
        <a href="/auth/logout" class="logout-link-animated"><span>🚪</span> 로그아웃</a>
      </div>
    </aside>
    <main class="main-content">
      <div class="page-header">
        <h1 class="title-md">🎭 역할 지급 설정</h1>
      </div>

      <div class="card mb-6">
        <div class="card-header">➕ 새 역할 보상 추가</div>
        <div class="grid-2" style="grid-template-columns: 1fr 1fr auto; align-items: end; gap: 1rem;">
          <div class="input-group">
            <label class="input-label">누적 소비 금액 (원)</label>
            <input type="number" id="spentLimit" placeholder="예: 10000" class="input">
          </div>
          <div class="input-group">
            <label class="input-label">지급할 역할 ID</label>
            <input type="text" id="roleId" placeholder="Discord 역할 ID" class="input">
          </div>
          <button onclick="addRole()" class="btn btn-primary" style="margin-bottom: 0.5rem;">추가하기</button>
        </div>
      </div>

      <div class="card">
        <div class="card-header">📜 역할 보상 목록</div>
        <div class="table-container">
          <table class="table">
            <thead>
              <tr>
                <th>누적 소비 금액</th>
                <th>역할 ID</th>
                <th>작업</th>
              </tr>
            </thead>
            <tbody id="roleList">
              <tr>
                <td colspan="3" class="text-muted">로딩중...</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </main>
  </div>

  <script>
    async function loadRoles() {
      const r = await fetch('/api/admin/roles');
      const d = await r.json();
      const tb = document.getElementById('roleList');
      if (d.length === 0) {
        tb.innerHTML = '<tr><td colspan="3" class="text-muted">설정된 역할 보상이 없습니다.</td></tr>';
        return;
      }
      tb.innerHTML = d.map(r => `
        <tr class="border-t border-gray-700">
          <td class="py-3">${r.spentLimit.toLocaleString()}원</td>
          <td class="py-3">${r.roleId}</td>
          <td class="py-3">
            <button onclick="deleteRole(${r.id})" class="text-danger hover:underline">삭제</button>
          </td>
        </tr>
      `).join("");
    }

    async function addRole() {
      const spentLimit = document.getElementById('spentLimit').value;
      const roleId = document.getElementById('roleId').value;
      if (!spentLimit || !roleId) return alert('모든 필드를 입력해주세요.');

      const r = await fetch('/api/admin/roles', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ spentLimit, roleId })
      });

      if (r.ok) {
        document.getElementById('spentLimit').value = '';
        document.getElementById('roleId').value = '';
        loadRoles();
      } else {
        alert('추가 실패');
      }
    }

    async function deleteRole(id) {
      if (!confirm('정말 삭제하시겠습니까?')) return;
      const r = await fetch(`/api/admin/roles/${id}`, { method: 'DELETE' });
      if (r.ok) loadRoles();
      else alert('삭제 실패');
    }

    loadRoles();
  </script>
  <script src="/js/common.js"></script>
</body>
</html>
