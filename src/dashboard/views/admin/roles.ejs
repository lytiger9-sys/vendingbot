<div class="mb-6">
  <h1 class="text-2xl font-bold">🎭 역할 지급 설정</h1>
</div>
<div class="bg-gray-800 rounded-lg p-6 mb-6">
  <h2 class="text-lg font-bold mb-4">역할 규칙 추가</h2>
  <form id="addRoleForm" class="flex gap-4 items-end">
    <div><label class="block text-sm text-gray-400">누적 구매 기준 (원)</label><input type="number" name="spentLimit" required
        class="w-40 p-2 rounded bg-gray-700 border border-gray-600"></div>
    <div><label class="block text-sm text-gray-400">역할 ID</label><input type="text" name="roleId" required
        placeholder="123456789" class="w-48 p-2 rounded bg-gray-700 border border-gray-600"></div>
    <button type="submit" class="px-6 py-2 bg-blue-600 hover:bg-blue-700 rounded">추가</button>
  </form>
</div>
<div class="bg-gray-800 rounded-lg p-6">
  <h2 class="text-lg font-bold mb-4">현재 역할 규칙</h2>
  <table class="w-full">
    <thead>
      <tr class="text-left text-gray-400">
        <th class="pb-3">순서</th>
        <th class="pb-3">누적 구매 기준</th>
        <th class="pb-3">역할 ID</th>
        <th class="pb-3">작업</th>
      </tr>
    </thead>
    <tbody id="roleList">
      <tr>
        <td colspan="4" class="text-gray-400">로딩중...</td>
      </tr>
    </tbody>
  </table>
</div>
<script>
  async function loadRoles() { const r = await fetch("/admin/roles"); const roles = await r.json(); const tbody = document.getElementById("roleList"); tbody.innerHTML = roles.length === 0 ? "<tr><td colspan=4 class=text-gray-400>규칙이 없습니다</td></tr>" : roles.map((r, i) => `<tr class="border-t border-gray-700"><td class="py-3">${i + 1}</td><td class="py-3">${r.spentLimit.toLocaleString()}원</td><td class="py-3 font-mono">${r.roleId}</td><td class="py-3"><button onclick="deleteRole(${r.id})" class="text-red-400 hover:underline">삭제</button></td></tr>`).join(""); }
  document.getElementById("addRoleForm").onsubmit = async function (e) { e.preventDefault(); const fd = new FormData(this); await fetch("/admin/roles", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ spentLimit: fd.get("spentLimit"), roleId: fd.get("roleId") }) }); this.reset(); loadRoles(); };
  async function deleteRole(id) { if (confirm("삭제하시겠습니까?")) { await fetch(`/admin/roles/${id}`, { method: "DELETE" }); loadRoles(); } }
  loadRoles();
</script>