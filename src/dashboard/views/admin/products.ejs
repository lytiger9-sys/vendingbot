<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>관리자 대시보드</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="dashboard-container">
    <aside class="sidebar">
      <h1 class="sidebar-title">🛒 자판기 봇</h1>
      <nav class="sidebar-nav">
        <a href="/admin" class="nav-link active"><span>📊</span> 월간 실적</a>
        <a href="/admin/products" class="nav-link"><span>📦</span> 제품</a>
        <a href="/admin/logs" class="nav-link"><span>📜</span> 로그</a>
        <a href="/admin/settings" class="nav-link"><span>⚙️</span> 설정</a>
        <a href="/admin/embed" class="nav-link"><span>💬</span> 임베드</a>
        <a href="/admin/roles" class="nav-link"><span>🎭</span> 역할 지급</a>
      </nav>
      <div class="sidebar-footer">
        <div class="user-id">ID: <%= user.id %></div>
        <a href="/dashboard" class="nav-link"><span>👤</span> 내 대시보드</a>
                <a href="/auth/logout" class="logout-link-animated"><span>🚪</span> 로그아웃</a>
      </div>
    </aside>
    <main class="main-content">
<div class="page-header">
  <h1 class="title-md">📊 월간 실적</h1>
</div>

<div class="stats-grid" style="grid-template-columns: repeat(4, 1fr);">
  <div class="stat-card">
    <div class="stat-icon">💰</div>
    <div class="stat-value text-primary" id="monthlySales">로딩중...</div>
    <div class="stat-label">총 매출</div>
  </div>
  <div class="stat-card">
    <div class="stat-icon">💳</div>
    <div class="stat-value text-primary" id="monthlyRecharge">로딩중...</div>
    <div class="stat-label">총 충전</div>
  </div>
  <div class="stat-card">
    <div class="stat-icon">🛒</div>
    <div class="stat-value text-primary" id="salesCount">로딩중...</div>
    <div class="stat-label">판매 건수</div>
  </div>
  <div class="stat-card">
    <div class="stat-icon">⚡</div>
    <div class="stat-value text-primary" id="rechargeCount">로딩중...</div>
    <div class="stat-label">충전 건수</div>
  </div>
</div>

<div class="card">
  <div class="card-header">🏆 인기 제품</div>
  <div class="table-container">
    <table class="table">
      <thead>
        <tr>
          <th>제품명</th>
          <th>판매건수</th>
          <th>총매출</th>
        </tr>
      </thead>
      <tbody id="topProducts">
        <tr>
          <td colspan="3" class="text-muted">로딩중...</td>
        </tr>
      </tbody>
    </table>
  </div>
</div>
<script>async function loadStats() { const r = await fetch("/admin/stats"); const d = await r.json(); document.getElementById("monthlySales").textContent = (d.monthlySales || 0).toLocaleString() + "원"; document.getElementById("monthlyRecharge").textContent = (d.monthlyRecharge || 0).toLocaleString() + "원"; document.getElementById("salesCount").textContent = d.salesCount || 0; document.getElementById("rechargeCount").textContent = d.rechargeCount || 0; const tb = document.getElementById("topProducts"); if (d.topProducts && d.topProducts.length > 0) { tb.innerHTML = d.topProducts.map(p => `<tr class="border-t border-gray-700"><td class="py-3">${p.product?.name || "알 수 없음"}</td><td class="py-3">${p._count}</td><td class="py-3">${(p._sum.paidAmount || 0).toLocaleString()}원</td></tr>`).join(""); } } loadStats();
</script>
</main>
  </div>
</body>
</html>