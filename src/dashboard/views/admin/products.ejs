<div class="mb-6 flex justify-between items-center">
  <h1 class="text-2xl font-bold">📦 제품 관리</h1>
  <button onclick="showAddCategory()" class="px-4 py-2 bg-green-600 hover:bg-green-700 rounded">카테고리 추가</button>
</div>
<div id="categories"></div>
<div id="addProductModal" class="hidden fixed inset-0 bg-black/50 flex items-center justify-center z-50">
  <div class="bg-gray-800 rounded-lg p-6 w-96">
    <h3 class="text-lg font-bold mb-4">제품 추가</h3>
    <form id="addProductForm" class="space-y-4">
      <input type="text" name="name" placeholder="제품명" required class="w-full p-2 rounded bg-gray-700 border border-gray-600">
      <input type="number" name="price" placeholder="가격" required class="w-full p-2 rounded bg-gray-700 border border-gray-600">
      <textarea name="description" placeholder="설명" class="w-full p-2 rounded bg-gray-700 border border-gray-600"></textarea>
      <select name="categoryId" id="productCategorySelect" class="w-full p-2 rounded bg-gray-700 border border-gray-600"></select>
      <div class="flex items-center gap-2">
        <input type="checkbox" name="isFixed" id="isFixedCheck">
        <label for="isFixedCheck">고정형</label>
      </div>
      <textarea name="fixedContent" id="fixedContentArea" placeholder="고정형 콘텐츠 (제품 정보 등)" class="w-full p-2 rounded bg-gray-700 border border-gray-600 hidden"></textarea>
      <div class="flex gap-2">
        <button type="submit" class="flex-1 py-2 bg-blue-600 hover:bg-blue-700 rounded">추가</button>
        <button type="button" onclick="hideModal()" class="flex-1 py-2 bg-gray-600 hover:bg-gray-500 rounded">취소</button>
      </div>
    </form>
  </div>
</div>
<script>
async function loadProducts(){
  const r=await fetch("/api/products");
  const data=await r.json();
  renderCategories(data);
  const sel=document.getElementById("productCategorySelect");
  sel.innerHTML=data.map(c=>`<option value="${c.id}">${c.name}</option>`).join("");
}
function renderCategories(data){
  const el=document.getElementById("categories");
  el.innerHTML=data.map(c=>`
    <div class="bg-gray-800 rounded-lg mb-4">
      <div class="p-4 border-b border-gray-700 flex justify-between items-center">
        <h3 class="font-bold text-lg">${c.name}</h3>
        <button onclick="addProduct(${c.id})" class="text-sm bg-blue-600 px-3 py-1 rounded hover:bg-blue-700">제품추가</button>
      </div>
      <div class="p-4">
        ${c.products.length===0?"<p class=\"text-gray-400\">제품이 없습니다</p>":c.products.map(p=>`
          <div class="bg-gray-700 rounded p-3 mb-2">
            <div class="flex justify-between">
              <span>${p.name}</span>
              <span class="text-green-400">${p.price.toLocaleString()}원</span>
            </div>
            <div class="text-sm text-gray-400">${p.isFixed?"고정형":"재고형"} | ${p.isFixed?"무제한":p.stocks.length+"개"}</div>
            <div class="mt-2 flex gap-2">
              ${p.isFixed?`<button onclick="editStocks(${p.id},\"fixed\")" class="text-xs bg-yellow-600 px-2 py-1 rounded">수정</button>`:`<button onclick="addStock(${p.id})" class="text-xs bg-green-600 px-2 py-1 rounded">재고추가</button>`}
              <button onclick="deleteProduct(${p.id})" class="text-xs bg-red-600 px-2 py-1 rounded">삭제</button>
            </div>
          </div>
        `).join("")}
      </div>
    </div>
  `).join("");
}
function showAddCategory(){
  const name=prompt("카테고리 이름:");
  if(name){fetch("/api/products/categories",{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({name})}).then(()=>loadProducts());}
}
function addProduct(catId){
  document.getElementById("productCategorySelect").value=catId;
  document.getElementById("addProductModal").classList.remove("hidden");
}
function hideModal(){document.getElementById("addProductModal").classList.add("hidden");}
document.getElementById("isFixedCheck").onchange=function(){document.getElementById("fixedContentArea").classList.toggle("hidden",!this.checked);};
document.getElementById("addProductForm").onsubmit=async function(e){
  e.preventDefault();
  const fd=new FormData(this);
  await fetch("/api/products",{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({name:fd.get("name"),price:fd.get("price"),description:fd.get("description"),categoryId:fd.get("categoryId"),isFixed:fd.get("isFixed")==="on",fixedContent:fd.get("fixedContent")})});
  hideModal();loadProducts();
};
async function addStock(id){
  const c=prompt("재고 내용:");
  if(c){await fetch(`/api/products/${id}/stocks`,{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({content:c})});loadProducts();}
}
async function deleteProduct(id){
  if(confirm("삭제하시겠습니까?")){await fetch(`/api/products/${id}`,{method:"DELETE"});loadProducts();}
}
loadProducts();
</script>