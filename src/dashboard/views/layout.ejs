<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>자판기 봇 대시보드</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="dashboard-container">
    <aside class="sidebar">
      <h1 class="sidebar-title">자판기 봇</h1>
      <nav class="sidebar-nav">
        <% if (isAdmin) { %>
        <a href="/admin" class="nav-link">📊 월간 실적</a>
        <a href="/admin/roles" class="nav-link">🎭 역할 지급</a>
        <a href="/admin/logs" class="nav-link">📜 로그</a>
        <a href="/admin/settings" class="nav-link">⚙️ 설정</a>
        <a href="/admin/products" class="nav-link">📦 제품</a>
        <% } else { %>
        <a href="/dashboard" class="nav-link">📊 내 통계</a>
        <% } %>
      </nav>
      <div class="sidebar-footer">
        <div class="user-id">ID: <%= user.id %></div>
        <a href="/auth/logout" class="logout-link">로그아웃</a>
      </div>
    </aside>
    <main class="main-content">
      <%- body %>
    </main>
  </div>
</body>
</html>
